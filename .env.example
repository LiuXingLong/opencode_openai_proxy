UPSTREAM_BASE_URL=https://opencode.ai/zen
LISTEN_ADDR=:8082
LOG_FILE=./logs/proxy.log
# 日志级别: debug / info / warn / error，默认 info
LOG_LEVEL=info
# 按路径前缀分发的路由表，JSON 格式
UPSTREAM_ROUTES={"/v1/responses": "https://opencode.ai/zen", "/opencode/v1/responses": "https://opencode.ai/zen", "/ollama/v1/responses": "http://127.0.0.1:11434"}
# 搜索配置（可选，不配也能工作）
BING_SEARCH_URL=https://www.bing.com/search?q=   # Bing 搜索地址，默认 https://www.bing.com/search?q=
BING_SEARCH_RESULT_COUNT=15                  # 搜索时抓取的页面数量(0-15)，默认 15
BING_SEARCH_CONCURRENCY=5                    # 并发抓取数，默认和 RESULT_COUNT 一致
BING_SEARCH_TIMEOUT=30                       # 搜索总超时秒数，默认 30
SEARCH_RETRY_COUNT=3                          # 搜索失败后重试次数（默认3，总共尝试4次）

UPSTREAM_BASE_URL=https://opencode.ai/zen
LISTEN_ADDR=:8082
LOG_FILE=./logs/proxy.log
# 日志级别: debug / info / warn / error，默认 info
LOG_LEVEL=info
# 按路径前缀分发的路由表，JSON 格式
UPSTREAM_ROUTES={"/v1/responses": "https://opencode.ai/zen", "/opencode/v1/responses": "https://opencode.ai/zen", "/ollama/v1/responses": "http://host.docker.internal:11434"}

# 屏蔽 web_search 工具，让 Codex CLI 自行通过 curl/bash 搜索（默认 true，不配置即为开启）
BLOCK_WEB_SEARCH=false

# 搜索后端: bing / searxng，默认 searxng
SEARCH_BACKEND=searxng

# SearXNG 地址（仅在 SEARCH_BACKEND=searxng 时使用）
SEARXNG_BASE_URL=http://host.docker.internal:8086
# 是否将 SearXNG 搜索结果发给模型总结（默认 false，直接格式化返回）
SEARXNG_SUMMARIZE=false

# Bing 搜索配置（仅在 SEARCH_BACKEND=bing 时使用）
BING_SEARCH_URL=https://www.bing.com/search?q=   # Bing 搜索地址，默认 https://cn.bing.com/search?q=
BING_SEARCH_RESULT_COUNT=15                      # 搜索时抓取的页面数量(0-15)，默认 15
BING_SEARCH_CONCURRENCY=10                       # 并发抓取数，默认和 RESULT_COUNT 一致
BING_SEARCH_TIMEOUT=30                           # 搜索总超时秒数，默认 30
SEARCH_RETRY_COUNT=3                             # 搜索失败后重试次数（默认3，总共尝试4次）